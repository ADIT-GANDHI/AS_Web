# -- Ajab Shahar static Next.js export - Apache rewrite rules --
# The site lives under /new/ (basePath).
# -----------------------------------------------------------------------

Options -Indexes

RewriteEngine On
RewriteBase /new/

# 1. Real files (JS, CSS, images, fonts) - serve directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Exact .html exists on disk - serve it (handles all listing pages)
RewriteCond %{DOCUMENT_ROOT}/new/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 3. Dynamic SPA stub - works for ANY detail section automatically.
#    If parent/0.html exists on disk, serve it. No need to hardcode routes.
#    e.g. songs/details/252 -> songs/details/0.html
#         poems/123         -> poems/0.html
#         people/67         -> people/0.html
RewriteCond %{REQUEST_URI} ^/new/(.+)/[^./]+/?$
RewriteCond %{DOCUMENT_ROOT}/new/%1/0.html -f
RewriteRule ^(.+)/[^./]+/?$ $1/0.html [L]

# 4. Final fallback for anything else
RewriteRule ^ /new/index.html [L]

ErrorDocument 404 /new/404.html
