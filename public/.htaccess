# -- Ajab Shahar static Next.js export - Apache rewrite rules --
# The site lives under /new/ (basePath).
# -----------------------------------------------------------------------

Options -Indexes

RewriteEngine On
RewriteBase /new/

# 1. Real files (JS, CSS, images, fonts) - serve directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. If path.html exists on disk, serve it (listing pages: /songs, /films, etc.)
RewriteCond %{DOCUMENT_ROOT}/new/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 3. Detail page SPA fallbacks - serve the correct section shell
#    Each shell hydrates with the right component; useParams() reads the real URL id.
RewriteRule ^songs/details/ songs/details/0.html [L]
RewriteRule ^reflections/details/ reflections/details/0.html [L]
RewriteRule ^films/details/ films/details/0.html [L]
RewriteRule ^poems/[^/]+ poems/0.html [L]
RewriteRule ^people/[^/]+ people/0.html [L]

# 4. Final fallback for any other unknown path
RewriteRule ^ /new/index.html [L]

# Custom 404 page
ErrorDocument 404 /new/404.html
