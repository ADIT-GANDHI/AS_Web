# Copy to .env.local for local development.

# --- Production (final stack) ---
# UI:  https://ajab.damnetworks.com
# API: https://ajab-admin.damnetworks.com/admin
NEXT_PUBLIC_AJAB_API_BASE=https://ajab-admin.damnetworks.com/admin

# Until ajab-admin DNS is live, use the admin server IP:
# NEXT_PUBLIC_AJAB_API_BASE=http://165.232.187.173/admin

# --- Legacy staging CMS ---
# NEXT_PUBLIC_AJAB_API_BASE=https://ajab.designanddevelopment.in/admin

# build:final   → root deploy for ajab.damnetworks.com (default — use this)
# npm run build → same as build:final (root, no prefix)
# build:staging-new → legacy /new staging only (not live)
# build:ajab      → subpath deploy at /ajab/ if ever needed

# Home Ajab News popup: set false to disable auto-open on `/` (footer CTA still works)
# NEXT_PUBLIC_AJAB_NEWS_AUTO_OPEN=false

# Home cards: set true to hide mocks and only show `/Api/home` sections (testing)
# NEXT_PUBLIC_HOME_API_ONLY=true
